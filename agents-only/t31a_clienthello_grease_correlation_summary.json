  "answers": {
    "1_go_reuses_one_grease_value_per_hello": "NO — 4-5 distinct GREASE values per hello",
    "2_go_uses_two_or_more_grease_values": "YES — 4-5 per hello",
    "3_fixed_cross_slot_correlation": "YES — supported_groups GREASE == key_share GREASE (10/10); two distinct extension-type GREASE (head/tail); cipher & supported_versions independent draws",
    "4_rust_fixed_slots": "ALL GREASE values fixed (cipher/groups/versions/key_share/ext-head/ext-tail)",
    "5_rust_randomized_slots": "NONE of the GREASE VALUES (ECH payload length and extension ORDER do randomize, but GREASE values do not)",
    "6_randomizing_cipher_alone_enough": "NO — Go randomizes ALL GREASE slots; fixing only cipher leaves 5 other fixed GREASE values, still distinguishable to a GREASE-value-entropy analyzer",
    "7_shared_selector_needed": "YES — a coordinated per-hello GREASE selector is required to preserve groups==key_share and to keep the two ext-type GREASE distinct; independent per-slot random would break the correlation and risk a duplicate extension type",
    "8_duplicate_extension_type_risk": "REAL if a naive selector picks the same GREASE value for both ext-type slots; current code keeps them distinct (10/10). The selector MUST guarantee ext-head != ext-tail"
  }
}
