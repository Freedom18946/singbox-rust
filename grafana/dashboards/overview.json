{
  "uid": "singbox-overview",
  "title": "SingBox-Rust · Overview",
  "description": "Current implementation overview for singbox-rust metrics",
  "tags": ["singbox-rust", "overview", "metrics"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "title": "DNS Dashboard",
      "url": "/d/singbox-dns",
      "icon": "dashboard",
      "type": "link"
    },
    {
      "title": "Proxy Dashboard",
      "url": "/d/singbox-proxy",
      "icon": "dashboard",
      "type": "link"
    },
    {
      "title": "UDP Dashboard",
      "url": "/d/singbox-udp",
      "icon": "dashboard",
      "type": "link"
    },
    {
      "title": "Routing Dashboard",
      "url": "/d/singbox-routing",
      "icon": "dashboard",
      "type": "link"
    }
  ],
  "panels": [
    {
      "type": "row",
      "id": 1,
      "title": "System Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Build Info",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sb_build_info",
          "legendFormat": "{{version}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "value" },
          "noValue": "N/A"
        }
      },
      "options": {
        "graphMode": "none",
        "colorMode": "background",
        "textMode": "name"
      }
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Uptime",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sb_uptime_seconds",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "value" }
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Prom Export Failures (15m)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(increase(prom_http_fail_total[15m])) or on() vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "graphMode": "none",
        "colorMode": "background"
      }
    },
    {
      "type": "stat",
      "id": 5,
      "title": "Healthy Proxies",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "count(proxy_up == 1) or on() vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "value" }
        }
      },
      "options": {
        "graphMode": "none",
        "colorMode": "value"
      }
    },
    {
      "type": "row",
      "id": 10,
      "title": "Traffic & Success",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "id": 11,
      "title": "Overall Request Rates",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(dns_query_total[5m]))",
          "legendFormat": "DNS",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_respond_total[5m]))",
          "legendFormat": "HTTP",
          "refId": "B"
        },
        {
          "expr": "sum(rate(outbound_connect_total[5m]))",
          "legendFormat": "Outbound",
          "refId": "C"
        },
        {
          "expr": "sum(rate(proxy_select_total[5m]))",
          "legendFormat": "Proxy Select",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last", "mean", "max"]
        },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "stat",
      "id": 12,
      "title": "DNS Success Rate",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "100 * sum(rate(dns_success_total[5m])) / clamp_min(sum(rate(dns_success_total[5m])) + sum(rate(dns_failed_total[5m])), 1e-9)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 90, "color": "yellow" },
              { "value": 99, "color": "green" }
            ]
          }
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "type": "stat",
      "id": 13,
      "title": "HTTP Success Rate",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "100 * sum(rate(http_respond_total{code=~\"2..|3..\"}[5m])) / clamp_min(sum(rate(http_respond_total[5m])), 1e-9)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 90, "color": "yellow" },
              { "value": 99, "color": "green" }
            ]
          }
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "type": "stat",
      "id": 14,
      "title": "HTTP Active Connections",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "http_active_connections",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "value" }
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "type": "row",
      "id": 20,
      "title": "Resources & Errors",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "type": "stat",
      "id": 21,
      "title": "UDP NAT Size",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "udp_nat_size",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 5000, "color": "yellow" },
              { "value": 9000, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "type": "stat",
      "id": 22,
      "title": "DNS Cache Size",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "dns_cache_size",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "value" }
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "type": "stat",
      "id": 23,
      "title": "Route Explain Calls (1h)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(increase(route_explain_total[1h])) or on() vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "value" }
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "type": "stat",
      "id": 24,
      "title": "Adapter Retries (1h)",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(increase(adapter_retries_total[1h])) or on() vector(0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 10, "color": "yellow" },
              { "value": 100, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "type": "timeseries",
      "id": 25,
      "title": "Error Rates by Component",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 19 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(dns_error_total[5m]))",
          "legendFormat": "DNS",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_errors_total[5m]))",
          "legendFormat": "HTTP",
          "refId": "B"
        },
        {
          "expr": "(sum(rate(outbound_connect_error_total[5m])) or on() vector(0)) + (sum(rate(outbound_error_total[5m])) or on() vector(0))",
          "legendFormat": "Outbound",
          "refId": "C"
        },
        {
          "expr": "sum(rate(udp_upstream_fail_total[5m]))",
          "legendFormat": "UDP Failures",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["last", "mean", "max"]
        },
        "tooltip": { "mode": "multi" }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "prometheus"
        }
      }
    ]
  },
  "annotations": {
    "list": []
  }
}
