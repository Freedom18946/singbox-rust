{
  "log": { "level": "warn" },
  "experimental": {
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "secret": "test-secret"
    }
  },
  "inbounds": [
    {
      "type": "socks",
      "tag": "socks-v4",
      "listen": "127.0.0.1",
      "listen_port": 11801
    },
    {
      "type": "socks",
      "tag": "socks-v6",
      "listen": "::1",
      "listen_port": 11802
    }
  ],
  "outbounds": [
    { "type": "direct", "tag": "direct" },
    { "type": "block", "tag": "block" }
  ],
  "route": {
    "rules": [
      {
        "rule_set": "source-ipv4",
        "rule_set_ip_cidr_match_source": true,
        "outbound": "direct"
      },
      { "port": [18898], "outbound": "direct" }
    ],
    "rule_set": [
      {
        "tag": "source-ipv4",
        "type": "local",
        "format": "source",
        "path": "labs/interop-lab/fixtures/routing/source_ipv4.json"
      }
    ],
    "final": "block"
  }
}
