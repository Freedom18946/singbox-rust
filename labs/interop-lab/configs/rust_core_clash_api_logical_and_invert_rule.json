{
  "log": {
    "level": "info"
  },
  "experimental": {
    "clash_api": {
      "external_controller": "127.0.0.1:19290",
      "secret": "test-secret"
    }
  },
  "inbounds": [
    {
      "type": "socks",
      "name": "socks-in",
      "listen": "127.0.0.1:11801"
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "name": "direct"
    },
    {
      "type": "block",
      "name": "block"
    }
  ],
  "route": {
    "rules": [
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "domain": [
              "localhost"
            ]
          },
          {
            "port": [
              "18897"
            ]
          }
        ],
        "outbound": "direct"
      },
      {
        "type": "logical",
        "mode": "and",
        "rules": [
          {
            "port": [
              "18898"
            ]
          },
          {
            "domain": [
              "blocked.invalid"
            ],
            "invert": true
          }
        ],
        "outbound": "direct"
      }
    ],
    "final": "block"
  }
}
