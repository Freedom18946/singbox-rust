{
  "log": { "level": "warn" },
  "experimental": {
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "secret": "test-secret"
    }
  },
  "inbounds": [
    { "type": "socks", "tag": "socks-in", "listen": "127.0.0.1", "listen_port": 11801 }
  ],
  "outbounds": [
    { "type": "direct", "tag": "direct" },
    { "type": "block", "tag": "block" }
  ],
  "route": {
    "rules": [
      { "rule_set": "remote-domains", "outbound": "direct" }
    ],
    "rule_set": [
      {
        "tag": "remote-domains",
        "type": "remote",
        "format": "source",
        "download_detour": "direct",
        "url": "http://127.0.0.1:19880/remote_domains.json"
      }
    ],
    "final": "block"
  }
}
