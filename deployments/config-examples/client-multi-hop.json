{
  "schema_version": 2,
  "log": {
    "level": "info"
  },
  "inbounds": [
    {
      "type": "socks",
      "name": "socks-in",
      "listen": "127.0.0.1:1080"
    }
  ],
  "outbounds": [
    {
      "type": "shadowsocks",
      "name": "ss-primary",
      "server": "primary.example.com",
      "port": 8388,
      "method": "chacha20-poly1305",
      "password": "CHANGE_THIS_PASSWORD"
    },
    {
      "type": "trojan",
      "name": "trojan-backup",
      "server": "backup.example.com",
      "port": 443,
      "password": "CHANGE_THIS_TROJAN_PASSWORD",
      "transport": [
        "tls",
        "grpc"
      ],
      "tls_sni": "backup.example.com",
      "grpc_service": "proxy.Service"
    },
    {
      "type": "direct",
      "name": "direct"
    },
    {
      "type": "block",
      "name": "block"
    }
  ],
  "route": {
    "rules": [
      {
        "when": {
          "suffix": [
            "lan.example",
            "internal.example"
          ]
        },
        "to": "direct"
      },
      {
        "when": {
          "suffix": [
            "backup.example.com"
          ]
        },
        "to": "trojan-backup"
      },
      {
        "when": {
          "suffix": [
            "ads.example.com"
          ]
        },
        "to": "block"
      }
    ],
    "default": "ss-primary"
  }
}
