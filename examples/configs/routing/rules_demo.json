{
  "schema_version": 2,
  "inbounds": [
    {
      "type": "mixed",
      "name": "mixed-in",
      "listen": "127.0.0.1:1080"
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "name": "direct"
    },
    {
      "type": "block",
      "name": "block"
    }
  ],
  "route": {
    "rules": [
      {
        "when": {
          "suffix": [
            "ads.example.com",
            "tracker.example.com"
          ]
        },
        "to": "block"
      },
      {
        "when": {
          "domain": [
            "example.com"
          ]
        },
        "to": "direct"
      },
      {
        "when": {
          "transport": "udp",
          "port": 53
        },
        "to": "direct"
      }
    ],
    "default": "direct"
  }
}
