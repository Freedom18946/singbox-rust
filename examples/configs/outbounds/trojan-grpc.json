{
  "schema_version": 2,
  "inbounds": [
    {
      "type": "socks",
      "name": "socks-in",
      "listen": "127.0.0.1",
      "port": 1082
    }
  ],
  "outbounds": [
    {
      "type": "trojan",
      "name": "trojan-grpc",
      "server": "example.com",
      "port": 443,
      "password": "change-me",
      "transport": [
        "tls",
        "grpc"
      ],
      "tls_sni": "example.com",
      "grpc_service": "proxy.Service"
    },
    {
      "type": "direct",
      "name": "direct"
    }
  ],
  "route": {
    "default": "trojan-grpc"
  }
}
