{
  "schema_version": 2,
  "inbounds": [
    {
      "type": "socks",
      "name": "socks-in",
      "listen": "127.0.0.1",
      "port": 1081
    }
  ],
  "outbounds": [
    {
      "type": "shadowsocks",
      "name": "ss-out",
      "server": "example.com",
      "port": 8388,
      "method": "aes-256-gcm",
      "password": "change-me"
    },
    {
      "type": "direct",
      "name": "direct"
    }
  ],
  "route": {
    "default": "ss-out"
  }
}
