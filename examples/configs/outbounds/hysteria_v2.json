{
  "schema_version": 2,
  "inbounds": [
    {
      "type": "hysteria2",
      "name": "hysteria2-in",
      "listen": "127.0.0.1:8443",
      "cert": "/path/to/cert.pem",
      "key": "/path/to/key.pem",
      "up_mbps": 100,
      "down_mbps": 100,
      "salamander": "replace-with-strong-salamander-password",
      "users": [
        {
          "password": "replace-with-strong-user-password-1"
        },
        {
          "password": "replace-with-strong-user-password-2"
        }
      ],
      "congestion_control": "bbr"
    }
  ],
  "outbounds": [
    {
      "type": "hysteria2",
      "name": "hysteria2-out",
      "server": "hysteria2.example.invalid",
      "port": 8443,
      "password": "replace-with-strong-user-password-1",
      "salamander": "replace-with-strong-salamander-password",
      "congestion_control": "bbr",
      "skip_cert_verify": false,
      "tls": {
        "enabled": true,
        "sni": "hysteria2.example.invalid"
      }
    },
    {
      "type": "direct",
      "name": "direct"
    }
  ],
  "route": {
    "rules": [],
    "default": "hysteria2-out"
  }
}
