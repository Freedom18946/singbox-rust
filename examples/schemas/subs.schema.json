{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Subscription Node List Schema",
  "description": "JSON Schema for validating exported subscription node lists.",
  "type": "array",
  "minItems": 1,
  "items": {
    "$ref": "#/definitions/node"
  },
  "definitions": {
    "port": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    },
    "node": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "tag": {
          "type": "string",
          "description": "Node identifier tag"
        },
        "name": {
          "type": "string",
          "description": "Alternative node identifier"
        },
        "type": {
          "type": "string",
          "enum": [
            "trojan",
            "vmess",
            "vless",
            "shadowsocks",
            "ss",
            "socks",
            "socks5",
            "http",
            "direct"
          ],
          "description": "Proxy protocol type"
        },
        "server": {
          "type": "string",
          "minLength": 1,
          "description": "Server hostname or IP address"
        },
        "server_port": {
          "$ref": "#/definitions/port",
          "description": "Server port number"
        },
        "port": {
          "$ref": "#/definitions/port",
          "description": "Alternative port field"
        },
        "password": {
          "type": "string",
          "minLength": 1,
          "description": "Authentication password"
        },
        "uuid": {
          "type": "string",
          "minLength": 1,
          "description": "VMess or VLESS user UUID"
        },
        "method": {
          "type": "string",
          "minLength": 1,
          "description": "Shadowsocks encryption method"
        },
        "username": {
          "type": "string",
          "description": "Optional HTTP/SOCKS username"
        },
        "network": {
          "type": "string"
        },
        "sni": {
          "type": "string"
        },
        "servername": {
          "type": "string"
        },
        "flow": {
          "type": "string"
        },
        "security": {
          "type": "string"
        },
        "alterId": {
          "type": "integer",
          "minimum": 0
        },
        "udp": {
          "type": "boolean"
        },
        "tls": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Whether TLS is enabled"
            },
            "server_name": {
              "type": "string",
              "description": "TLS Server Name Indication"
            },
            "insecure": {
              "type": "boolean",
              "description": "Skip certificate verification"
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": { "const": "direct" }
            },
            "required": ["type"]
          },
          "then": {
            "not": {
              "anyOf": [
                { "required": ["server"] },
                { "required": ["server_port"] },
                { "required": ["port"] }
              ]
            }
          },
          "else": {
            "required": ["server"],
            "anyOf": [
              { "required": ["server_port"] },
              { "required": ["port"] }
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": { "const": "trojan" }
            },
            "required": ["type"]
          },
          "then": {
            "required": ["password"]
          }
        },
        {
          "if": {
            "properties": {
              "type": { "enum": ["shadowsocks", "ss"] }
            },
            "required": ["type"]
          },
          "then": {
            "required": ["method", "password"]
          }
        },
        {
          "if": {
            "properties": {
              "type": { "enum": ["vmess", "vless"] }
            },
            "required": ["type"]
          },
          "then": {
            "required": ["uuid"]
          }
        },
        {
          "if": {
            "properties": {
              "type": { "enum": ["http", "socks", "socks5"] }
            },
            "required": ["type"]
          },
          "then": {
            "anyOf": [
              {
                "not": {
                  "anyOf": [
                    { "required": ["username"] },
                    { "required": ["password"] }
                  ]
                }
              },
              { "required": ["username", "password"] }
            ]
          }
        }
      ]
    }
  }
}
