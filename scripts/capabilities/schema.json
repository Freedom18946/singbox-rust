{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "singbox-rust capabilities report",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "source_commit",
    "profile",
    "capabilities",
    "claims"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_commit": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "type": "string"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "compile_state",
          "runtime_state",
          "verification_state",
          "overall_state",
          "accepted_limitation",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "compile_state": {
            "type": "string",
            "enum": [
              "supported",
              "gated_off",
              "stubbed",
              "absent"
            ]
          },
          "runtime_state": {
            "type": "string",
            "enum": [
              "verified",
              "unverified",
              "unsupported",
              "blocked"
            ]
          },
          "verification_state": {
            "type": "string",
            "enum": [
              "e2e_verified",
              "integration_verified",
              "compile_only",
              "no_evidence"
            ]
          },
          "overall_state": {
            "type": "string",
            "enum": [
              "implemented_verified",
              "implemented_unverified",
              "scaffold_stub"
            ]
          },
          "accepted_limitation": {
            "type": "boolean"
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "kind",
                "path",
                "line",
                "note"
              ],
              "properties": {
                "kind": {
                  "type": "string",
                  "minLength": 1
                },
                "path": {
                  "type": "string",
                  "minLength": 1
                },
                "line": {
                  "type": "integer",
                  "minimum": 1
                },
                "note": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_path",
          "line",
          "text",
          "risk_level",
          "linked_capability_ids"
        ],
        "properties": {
          "source_path": {
            "type": "string",
            "minLength": 1
          },
          "line": {
            "type": "integer",
            "minimum": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "risk_level": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "linked_capability_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
