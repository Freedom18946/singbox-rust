{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "singbox-rust capabilities report",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "source_commit",
    "profile",
    "acceptance_closure",
    "capabilities",
    "claims"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.1.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_commit": {
      "type": "string",
      "minLength": 1
    },
    "profile": {
      "type": "string"
    },
    "acceptance_closure": {
      "type": "object",
      "required": [
        "status",
        "evidence_scope",
        "snapshot_verifiability",
        "evidence"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "snapshot_unverified",
            "evidence_backed"
          ]
        },
        "evidence_scope": {
          "type": "string",
          "minLength": 1
        },
        "snapshot_verifiability": {
          "type": "string",
          "enum": [
            "slim_snapshot",
            "self_contained"
          ]
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "kind",
              "path",
              "line",
              "note"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "minLength": 1
              },
              "path": {
                "type": "string",
                "minLength": 1
              },
              "line": {
                "type": "integer",
                "minimum": 1
              },
              "note": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "compile_state",
          "runtime_state",
          "verification_state",
          "overall_state",
          "accepted_limitation",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "parent_capability_id": {
            "type": "string",
            "minLength": 1
          },
          "compile_state": {
            "type": "string",
            "enum": [
              "supported",
              "gated_off",
              "stubbed",
              "absent"
            ]
          },
          "runtime_state": {
            "type": "string",
            "enum": [
              "verified",
              "unverified",
              "unsupported",
              "blocked"
            ]
          },
          "verification_state": {
            "type": "string",
            "enum": [
              "e2e_verified",
              "integration_verified",
              "compile_only",
              "no_evidence"
            ]
          },
          "overall_state": {
            "type": "string",
            "enum": [
              "implemented_verified",
              "implemented_unverified",
              "scaffold_stub"
            ]
          },
          "accepted_limitation": {
            "type": "boolean"
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "kind",
                "path",
                "line",
                "note"
              ],
              "properties": {
                "kind": {
                  "type": "string",
                  "minLength": 1
                },
                "path": {
                  "type": "string",
                  "minLength": 1
                },
                "line": {
                  "type": "integer",
                  "minimum": 1
                },
                "note": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "runtime_probe": {
            "type": "object",
            "required": [
              "compile_state",
              "runtime_state",
              "requested",
              "summary",
              "details"
            ],
            "properties": {
              "compile_state": {
                "type": "string",
                "enum": [
                  "supported",
                  "gated_off",
                  "stubbed",
                  "absent"
                ]
              },
              "runtime_state": {
                "type": "string",
                "enum": [
                  "verified",
                  "unverified",
                  "unsupported",
                  "blocked"
                ]
              },
              "requested": {
                "type": "boolean"
              },
              "summary": {
                "type": "string"
              },
              "details": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "runtime_probe": {
      "type": "object",
      "required": [
        "source_path",
        "generated_at",
        "probe_mode",
        "probe_count"
      ],
      "properties": {
        "source_path": {
          "type": "string",
          "minLength": 1
        },
        "generated_at": {
          "type": "string"
        },
        "probe_mode": {
          "type": "string"
        },
        "probe_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_path",
          "line",
          "text",
          "risk_level",
          "claim_kind",
          "linked_ids"
        ],
        "properties": {
          "source_path": {
            "type": "string",
            "minLength": 1
          },
          "line": {
            "type": "integer",
            "minimum": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "risk_level": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "claim_kind": {
            "type": "string",
            "enum": [
              "capability",
              "closure",
              "historical"
            ]
          },
          "linked_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
